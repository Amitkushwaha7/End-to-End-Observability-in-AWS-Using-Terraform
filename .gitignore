# =============================================================================
# TERRAFORM
# =============================================================================

# Local .terraform directories
**/.terraform/*

# Terraform lock file (keep this for reproducible builds)
# .terraform.lock.hcl  ← Keep this committed

# Terraform state files - NEVER commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan files - binary, not human-readable
tfplan
*.tfplan
*.tfplan.*

# Terraform variable files with sensitive data
terraform.tfvars
# Keep the example file: terraform.tfvars.example is fine to commit

# Terraform crash log
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# =============================================================================
# LAMBDA & BUILD ARTIFACTS
# =============================================================================

# Lambda zip (auto-generated by Terraform archive_file data source)
lambda_function.zip

# Pillow layer zip (built by build_layer_docker.sh) - it's large (~40MB)
pillow_layer.zip

# General zip files
*.zip

# =============================================================================
# SENSITIVE / TEST FILES
# =============================================================================

# Downloaded test files
downloaded-secret.txt
*.secret.*

# PDF files (emails, documents accidentally added)
*.pdf

# =============================================================================
# AWS & CLOUD
# =============================================================================

# AWS credentials and config
.aws/
aws-credentials

# =============================================================================
# OS FILES
# =============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Windows
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Linux
*~

# =============================================================================
# EDITORS & IDEs
# =============================================================================

# VS Code (keep .vscode/extensions.json and settings.json optionally)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains IDEs
.idea/
*.iml

# Vim
*.swp
*.swo

# =============================================================================
# LOGS & TEMP
# =============================================================================

# Log files
*.log

# Temporary files
*.tmp
*.temp
tmp/
temp/

# Python cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
